<div class="author">
    <h1 class="author__heading">John Doe</h1>
    <p class="author__body">
        John Doe is a software engineer with over 10 years of experience in web development. He specializes in JavaScript and has a passion for creating intuitive user interfaces. In his free time, John enjoys hiking and photography.
    </p>
</div>
<img src="/assets/images/RR148_visual.jpg" alt="John Doe" class="author__image" width="980" height="654">
<section class="author__section">
    <h2 class="author__subheading">Career Highlights</h2>
    <ul class="author__list">
        <% data.forEach(element => { %>
         <li>
            <a href="/post/<%= element._id %>" class="author__link">
                <span><%- element.title %></span>
                <span class="author__date"><%- element.createdAt.toLocaleDateString() %></span>
            </a>
        </li>
        <% }) %>
        
    </ul>
    <% if (nextpage !== null) { %>
        <a href="?page=<%= parseInt(nextpage) %>" class="pagination">&lt; view previous posts</a>
    <% } %>
</section>